# SQLite database (libsql). Local file by default; point at a mounted volume in production.
DATABASE_URL=file:local.db

# Cookieless analytics (Umami/Plausible). Leave unset to disable (no script, no cookies).
# PUBLIC_ANALYTICS_SRC=https://analytics.example.com/script.js
# PUBLIC_ANALYTICS_WEBSITE_ID=00000000-0000-0000-0000-000000000000

# Email. Unset → the "log" dev driver just prints the message (no send), so the
# whole report flow works locally without a provider. To actually send, set EMAIL_DRIVER=http
# and provide a key; the HTTP driver targets a Resend-compatible JSON API (override EMAIL_ENDPOINT
# for another provider). EMAIL_FROM must be an address on your SPF/DKIM-verified domain.
# EMAIL_DRIVER=http
# EMAIL_ENDPOINT=https://api.resend.com/emails
# EMAIL_API_KEY=
# EMAIL_FROM=B2B Simulator <report@your-domain>
# Optional consultation CTA shown in the report footer.
# CONSULTATION_URL=https://your-domain/consultation
# Global send caps (abuse/cost guard). Defaults 80/day, 2500/month — safely under Resend's free
# tier (100/day, 3000/month). Once hit, /api/report returns 429 without calling the provider.
# EMAIL_DAILY_CAP=80
# EMAIL_MONTHLY_CAP=2500

# Where served report PDFs are written. Default: .reports (relative to cwd). In prod set
# this to a path on the app's mounted volume, e.g. /data/reports. PDFs are handed out via a
# tokenised download link and swept after ~3 days (the sim data stays in the DB).
# REPORTS_DIR=/data/reports

# Premium (Pro) entitlement launch flag. Fails OPEN to free: Pro is granted to
# everyone (incl. anonymous) unless this is explicitly 'false'. Leaving it unset keeps every
# premium feature open, matching today's behaviour. Set to 'false' once real entitlement
# checks are wired in.
# PRO_LAUNCH_FREE_FOR_ALL=true

# Auth (Better Auth magic-link). SECRET signs sessions/tokens - generate with
# `openssl rand -base64 32` and keep it in the server-side .env only (never commit it).
# BETTER_AUTH_URL is the site's public base URL; it must be set in production so magic-link
# URLs are built correctly. Magic-link emails reuse the EMAIL_* seam above (the log driver
# prints the link locally, so sign-in works in dev with no provider).
# BETTER_AUTH_SECRET=change-me-32-plus-random-chars
# BETTER_AUTH_URL=http://localhost:5173   # prod: https://example.com

# Law-change alerts. Runs from the CLI ingest script (pnpm ingest:derrama --
# --activate), diffing subscribers' saved scenarios against the dataset it replaces and
# emailing the ones materially affected (reuses BETTER_AUTH_URL for links + the EMAIL_*
# seam above). This is a per-RUN cap (operator-triggered batch, not a public endpoint) —
# a safety net against a misconfigured ingest fanning out to everyone at once.
# ALERT_RUN_MAX_EMAILS=500

# --- Production (container) ---
# The container deploy sets the non-secret infra vars in compose.yaml (DATABASE_URL,
# REPORTS_DIR, ORIGIN, HOST/PORT). The server-side .env next to compose.yaml (chmod 600,
# NOT committed) holds the secrets: the email provider key + BETTER_AUTH_SECRET, e.g.:
#   EMAIL_DRIVER=http
#   EMAIL_API_KEY=your_provider_key
#   EMAIL_FROM=B2B Simulator <noreply@example.com>
#   BETTER_AUTH_SECRET=...   BETTER_AUTH_URL=https://example.com
# (+ optional CONSULTATION_URL / EMAIL_DAILY_CAP / EMAIL_MONTHLY_CAP overrides)
